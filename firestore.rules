rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'rktechteam10@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Poems Collection (Publicly readable)
    match /poems/{poemId} {
      allow list: if true;
      allow get: if isValidId(poemId);
      allow write: if isAdmin();
    }

    // 2. User Data (Private)
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isOwner(userId) && incoming().uid == userId;
      allow update: if isOwner(userId) && incoming().uid == userId;
      
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 3. Test Connection
    match /test/connection {
      allow read: if true;
    }

    function incoming() { return request.resource.data; }
  }
}
